<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left color border -->
        <View
            android:id="@+id/cardBorder"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#6366F1" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Row 1: Sender + Time -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">

                <TextView android:id="@+id/tvSender"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textStyle="bold" android:textSize="14sp" android:textColor="#111827" />

                <TextView android:id="@+id/tvTimestamp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#9CA3AF" />

            </LinearLayout>

            <!-- Row 2: Message preview -->
            <TextView android:id="@+id/tvPreview"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="13sp" android:textColor="#6B7280"
                android:maxLines="2" android:ellipsize="end" />

            <!-- Row 3: Category + Risk badge + Score -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView android:id="@+id/tvCategory"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="#EDE9FE" android:textColor="#6366F1"
                    android:paddingStart="8dp" android:paddingEnd="8dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp"
                    android:textSize="11sp" android:textStyle="bold" />

                <TextView android:id="@+id/tvRiskBadge"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:paddingStart="8dp" android:paddingEnd="8dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp"
                    android:textSize="11sp" android:textStyle="bold" />

                <TextView android:id="@+id/tvRiskScore"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textSize="13sp" android:textStyle="bold" />

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                <TextView android:id="@+id/tvConfidence"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#9CA3AF" />

            </LinearLayout>

            <!-- Phishing warning -->
            <TextView android:id="@+id/tvPhishingWarning"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="🎣 Phishing attempt detected — do NOT click any links"
                android:textSize="12sp" android:textColor="#C62828"
                android:background="#FFEBEE"
                android:padding="6dp"
                android:visibility="gone" />

            <!-- Suspicious keywords -->
            <TextView android:id="@+id/tvKeywords"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="11sp" android:textColor="#92400E"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
