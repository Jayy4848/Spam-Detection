{
  "name": "textguard-ai",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && venv\\Scripts\\python.exe manage.py runserver 0.0.0.0:8000",
    "frontend": "cd frontend && npm start",
    "install:frontend": "cd frontend && npm install",
    "build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
