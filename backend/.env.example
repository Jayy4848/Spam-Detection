# Copy this to .env and fill in real values
# NEVER commit .env to git

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# Set to 'production' for deployment
DJANGO_ENV=development

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Custom admin URL (change from default!)
ADMIN_URL=my-secret-admin-path/

# API keys (SHA-256 hashes of actual keys)
# Generate: python -c "import hashlib; print(hashlib.sha256(b'your-key').hexdigest())"
VALID_API_KEYS=
